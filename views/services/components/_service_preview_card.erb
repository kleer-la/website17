<%
  subtitle_raw = service.subtitle.to_s
  heading_match = subtitle_raw.match(/<h[1-6][^>]*>(.*?)<\/h[1-6]>/im)
  subtitle_text = if heading_match
    heading_match[1].gsub(/<[^>]*>/, '').strip
  else
    subtitle_raw.gsub(/<[^>]*>/, '').strip
  end
%>
<a class="service-preview-card text-decoration-none d-flex flex-column h-100"
   href="/<%= session[:locale] %>/<%= @path %>/<%= area_slug %>/<%= service.slug %>"
   style="background: white; border: 3px solid <%= primary_color %>;">
  <h3><%= service.name %></h3>
  <% unless subtitle_text.empty? %>
    <p class="service-preview-subtitle flex-grow-1"><%= subtitle_text %></p>
  <% end %>
  <span class="btn service-preview-cta" style="background-color: transparent; color: <%= @primary_font_color || '#333' %>; border: 2px solid <%= primary_color %>; border-radius: 50px;">
    Ver más
  </span>
</a>
