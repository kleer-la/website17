<section class="news-hero">
  <h1><%= @page&.sections&.dig('hero', 'title') || t('news.title') %></h1>
  <% subtitle = @page&.sections&.dig('hero', 'content') %>
  <% if subtitle %>
    <p class="hero-description"><%= subtitle %></p>
  <% end %>
</section>

<section class="news-grid">
  <div class="container">
    <div class="row justify-content-center">
      <% @news.each_with_index do |news, index| %>
        <div class="col-sm-6 col-lg-4 mb-4 <%= 'hidden-news' if index >= 9 %>">
          <div class="news-card">
            <div class="news-card__image">
              <img src="<%= news.img.to_s != '' ? news.img : cdn('placeholder.png') %>"
                   alt="<%= news.title %>"
                   loading="<%= index < 6 ? 'eager' : 'lazy' %>"
                   decoding="async" />
            </div>
            <div class="news-card__body">
              <div class="news-card__meta">
                <%= news.event_date %>
                <% if news.trainers.count > 0 %>
                  &middot; <%= news.trainers.join(', ') %>
                <% end %>
              </div>
              <h3 class="news-card__title"><%= news.title %></h3>
              <p class="news-card__excerpt"><%= news.description %></p>
              <div class="news-card__links">
                <% unless news.video.to_s == '' %>
                  <a href="<%= news.video %>" target="_blank" class="news-card__link" title="<%= t('news.buttons.video') %>" aria-label="<%= t('news.buttons.video') %>">
                    <i class="fas fa-play-circle"></i> <%= t('news.buttons.video') %>
                  </a>
                <% end %>
                <% unless news.audio.to_s == '' %>
                  <a href="<%= news.audio %>" target="_blank" class="news-card__link" title="<%= t('news.buttons.audio') %>" aria-label="<%= t('news.buttons.audio') %>">
                    <i class="fas fa-music"></i> <%= t('news.buttons.audio') %>
                  </a>
                <% end %>
                <% unless news.url.to_s == '' %>
                  <a href="<%= news.url %>" target="_blank" class="news-card__link" title="<%= t('news.buttons.external') %>" aria-label="<%= t('news.buttons.external') %>">
                    <i class="fas fa-external-link-alt"></i> <%= t('news.buttons.external') %>
                  </a>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <% if @news.length > 9 %>
      <div class="text-center mt-3 mb-4">
        <button id="seeMoreBtn" class="btn news-see-more-btn">
          <span id="seeMoreText"><%= t('news.see_more', default: 'Ver más') %></span>
        </button>
      </div>
    <% end %>
  </div>
</section>

<section class="news-cta">
  <div class="container text-center">
    <h2><%= t('news.cta_title') %></h2>
    <p><%= t('news.cta_description') %></p>
    <div class="btn-center-container mt-4">
      <%= erb :'component/_contact_banner_button',
              locals: {
                text_button: t('news.cta_button'),
                style_class: 'btn my-primary-button',
                style: '',
                specific_id: 'news-cta-btn'
              } %>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var showingAll = false;
    var hiddenNews = document.querySelectorAll('.hidden-news');
    var seeMoreBtn = document.getElementById('seeMoreBtn');
    var seeMoreText = document.getElementById('seeMoreText');

    if (seeMoreBtn) {
      seeMoreBtn.addEventListener('click', function(event) {
        event.preventDefault();
        var isHidden = !showingAll;

        hiddenNews.forEach(function(card) {
          card.style.display = isHidden ? '' : 'none';
        });

        seeMoreText.textContent = isHidden ?
          '<%= t('news.see_less', default: 'Ver menos') %>' :
          '<%= t('news.see_more', default: 'Ver más') %>';

        showingAll = isHidden;

        if (!isHidden) {
          var prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          document.querySelector('.news-grid').scrollIntoView({
            behavior: prefersReducedMotion ? 'auto' : 'smooth',
            block: 'start'
          });
        }
      });
    }
  });
</script>
