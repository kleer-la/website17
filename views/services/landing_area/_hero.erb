<section class="area-hero-full position-relative d-flex align-items-center justify-content-center overflow-hidden"
  style="min-height: 80vh; margin-top: 0; background: linear-gradient(to bottom, <%= @primary_color %> 0%, <%= @primary_color %> 70%, <%= @primary_color %>44 100%);">

  <!-- Content -->
  <div class="position-relative px-3" style="z-index: 2; max-width: 1100px; width: 100%; padding-top: 6rem; color: <%= @primary_font_color %>;">
    <!-- Title -->
    <h1 class="text-uppercase mb-3"
      style="font-weight: 700; font-size: clamp(1.25rem, 2.5vw, 1.75rem); line-height: 1.3; letter-spacing: 0.15em; opacity: 0.9;">
      <%= service_area.name %>
    </h1>

    <!-- Subtitle (rendered as HTML with scoped styles) -->
    <% if service_area.subtitle && service_area.subtitle.strip != '' %>
      <div class="area-hero-subtitle mb-4">
        <%= service_area.subtitle %>
      </div>
    <% end %>

    <!-- Service links -->
    <% if service_area.services.any? %>
      <div class="d-flex flex-column flex-sm-row flex-wrap justify-content-center align-items-center gap-4 mb-5">
        <% service_area.services.each do |service| %>
          <a href="/<%= session[:locale] %>/<%= @path %>/<%= service_area.slug %>/<%= service.slug %>"
            class="area-hero-service-link"
            style="color: <%= @primary_font_color %>; font-weight: 700; font-size: 1.4rem; transition: opacity 0.2s; text-decoration: underline; text-underline-offset: 4px;">
            <%= service.name %>
          </a>
        <% end %>
      </div>
    <% end %>

    <!-- CTA Button -->
    <div class="text-center">
      <%= erb :'component/_contact_banner_button',
              locals: {
                style: "background-color: #{@secondary_color}; color: #{@secondary_font_color}; font-weight: 800; font-size: 1.1rem; padding: 16px 48px; border-radius: 50px; border: none; box-shadow: 0 8px 32px rgba(0,0,0,0.3); transition: transform 0.2s;",
                text_button: hero_cta,
                style_class: 'btn area-hero-cta-btn',
                specific_id: "area-hero-cta"
              } %>
    </div>
  </div>
</section>

<style>
  .area-hero-full {
    margin-top: 0 !important;
  }
  .area-hero-subtitle h2 {
    font-weight: 800;
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: inherit;
    margin-bottom: 0.5rem;
  }
  .area-hero-subtitle div,
  .area-hero-subtitle p {
    font-size: 1.3rem;
    line-height: 1.6;
    opacity: 0.9;
    color: inherit;
  }
  .area-hero-service-link:hover {
    opacity: 0.8;
  }
  .area-hero-cta-btn:hover {
    transform: scale(1.05);
  }
  .area-hero-cta-btn:active {
    transform: scale(0.95);
  }
</style>
