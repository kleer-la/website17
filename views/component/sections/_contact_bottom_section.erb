<section id="newsletter-subscription" class="mt-4">
  <div class="container contact__container">
    <div class="row align-items-center">
      <div class="col-lg-6 contact__img-container">
        <img
          src="/app/img/contact_section.png"
          alt="Contact"
          class="contact__img"
          loading="lazy"
        >
      </div>
      <div class="col-lg-6 contact__text">
        <h2 class="mb-3">
          <%=
            contact_text || "Contáctanos para llevar este servicio a tu organización."
          %>
        </h2>
        <div>
          <%= erb :'component/_contact_banner_button',
                  locals: {
                    style: "",
                    text_button: button_text, style_class: 'btn my-primary-button',
                    specific_id: ""
                  }%>
        </div>
      </div>
    </div>
  </div>
</section>
