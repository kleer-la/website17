<section id="course-hero">
  <div class="row h-100">
    <div class="col-md-9 course-hero__text">
      <h1><%= @event_type.name %></h1>
      <h2 class="hero-description"><%= @event_type.subtitle %></h2>
    </div>
    <div class="col-md-3 course-hero__button">
        <a data-bs-toggle="modal" data-bs-target="#incompany-quote-modal">
          <strong><%= t("course_landing.quote_incompany") %></strong>
        </a>
    </div>
  </div>
  <img src="<%= cdn('website-assets/rustic_worm.svg') %>" alt="" class="course-hero__rustic-worm" width="117" height="75"/>
</section>
