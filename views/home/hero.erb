<%
hero_item = t("home.home_hero").first
hero_data = section_data(@page, 'hero', { title: hero_item[:subject], content: hero_item[:description], cta_text: hero_item[:button_text] })
titles = to_lines(hero_data[:title])
description = hero_data[:content]
cta_url = hero_item[:url]
cta_text = hero_data[:cta_text]
%>
<section id="hero2" class="hero2">
  <img
    src="/app/img/hero_home.png"
    class="hero__img"
    alt="<%= hero_item[:alt] %>"
  >
  <div class="container hero__content">
    <div class="row">
      <div class="col-lg-7 carousel__text">
        <div>
          <h1>
            <span class="highlight highlight--first"><%= titles[0] %></span>
            <span class="highlight"><%= titles[1] %></span>
            <span class="highlight"><%= titles[2] %></span>
          </h1>
          <p><strong><%= description %></strong></p>
        </div>
        <button type="button" class="btn my-primary-button modal-opener"
          data-bs-toggle="modal" data-bs-target="#mail-modal">
          <%= cta_text %>
        </button>
      </div>
    </div>
  </div>
</section>