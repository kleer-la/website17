<div class="col-12 col-md-6 col-lg-4 mb-4">
<%
  path = {'es'=> 'es/servicios', 'en'=> 'en/services'}[session[:locale]]
%>
  <a
    href="<%= area.slug ? "/#{path}/#{area.slug}" : "#" %>"
    class="card service-area-card text-decoration-none h-100"
    style="background: linear-gradient(<%= area.primary_color %>, <%= area.primary_color %>22); border-color: <%= area.primary_color %>;"
  >
    <div class="card-body p-3 d-flex flex-column">
      <h3 class="card-title"><%= area.name %></h3>
      <% card_text = area.summary ? area.summary.gsub(/<[^>]*>/, '').strip : nil %>
      <% if card_text && !card_text.empty? %>
        <p class="card-subtitle flex-grow-1"><%= smart_truncate(card_text, 200) %></p>
      <% end %>
      <% cta = area.cta_message ? area.cta_message.gsub(/<[^>]*>/, '').strip : nil %>
      <span class="btn card-cta mt-2" style="background-color: transparent; color: <%= area.primary_color %>; border: 2px solid <%= area.primary_color %>;"><%= cta && !cta.empty? ? cta : t('home.home_courses.button.title') %></span>
    </div>
  </a>
</div>