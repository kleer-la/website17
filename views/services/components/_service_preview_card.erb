<%
  subtitle_text = service.subtitle.to_s.gsub(/<[^>]*>/, '').strip
%>
<a class="service-preview-card" href="/<%= session[:locale] %>/<%= @path %>/<%= area_slug %>/<%= service.slug %>"
   style="border-bottom: 4px solid <%= primary_color %>; --card-primary-color: <%= primary_color %>;">
  <h3 style="color: <%= primary_color %>;"><%= service.name %></h3>
  <% unless subtitle_text.empty? %>
    <p class="service-preview-subtitle"><%= subtitle_text %></p>
  <% end %>
  <span class="service-preview-cta" style="color: <%= primary_color %>;">
    Ver más →
  </span>
</a>
