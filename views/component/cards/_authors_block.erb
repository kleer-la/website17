<%
  if authors.length <= 1
%>
  <div class="invidivual-author">
    <% if defined?(title) %>
      <b><%= title %>: </b>
    <% else %>
      <img
        src="/img/icons/blue_user.svg"
        alt=""
        class="little-icon me-2"
        />
    <% end %>
    <%= authors[0] %>
  </div>
<% else%>
  <div class="more-authors rounded">
    <div class="more-authors__summary">
      <% if defined?(title) %>
        <b><%= title %>: </b>
      <% end %>
      <img
        src="/img/icons/blue_user.svg"
        alt=""
        class="little-icon me-2"
        />
      <%= authors[0] %>
      <i class="fas fa-chevron-down ms-1 more-authors__chevron"></i>
    </div>

    <div class="more-authors__popup">
      <% authors.each do |author| %>
        <div class="invidivual-author">
          <img
            src="/img/icons/blue_user.svg"
            alt=""
            class="little-icon ms-4"
            />
          <%= author %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
