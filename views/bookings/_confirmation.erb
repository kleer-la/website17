<div class="booking-confirmation text-center py-5">
  <div class="booking-confirmation__icon mb-3">
    <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="currentColor" class="text-success" viewBox="0 0 16 16">
      <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0m-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
    </svg>
  </div>
  <h2><%= t('booking.meeting_confirmed') %></h2>
  <p class="lead">
    <%= t('booking.with_consultant', name: booking[:consultant_name]) %>
  </p>
  <p>
    <strong><%= booking[:starts_at] %></strong>
  </p>
  <% if booking[:google_meet_link] %>
    <p>
      <%= t('booking.meet_link') %>:
      <a href="<%= booking[:google_meet_link] %>" target="_blank" rel="noopener noreferrer">
        <%= booking[:google_meet_link] %>
      </a>
    </p>
  <% end %>
  <p class="text-muted mt-3"><%= t('booking.success') %></p>
</div>
