<%#content_for :header do %>
<%#end%>

<div id="reading-progress" class="reading-progress"></div>

<article id="landing-blog">
  <%= erb :'blog/landing_blog/hero' %>
  <%= erb :'blog/landing_blog/body', locals: {titles: titles, body: body} %>
  <%= erb :'component/sections/recommended', locals: { recommended: @article.recommended, title: t('recommended.title') }%>
</article>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var progressBar = document.getElementById('reading-progress');
  var article = document.getElementById('landing-blog');
  var ticking = false;

  function updateProgress() {
    var articleTop = article.offsetTop;
    var articleHeight = article.offsetHeight;
    var scrolled = window.scrollY - articleTop;
    var progress = Math.min(Math.max(scrolled / (articleHeight - window.innerHeight), 0), 1);
    progressBar.style.width = (progress * 100) + '%';
    ticking = false;
  }

  window.addEventListener('scroll', function() {
    if (!ticking) {
      requestAnimationFrame(updateProgress);
      ticking = true;
    }
  }, { passive: true });
});
</script>
