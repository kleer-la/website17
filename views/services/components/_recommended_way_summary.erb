<%
  # Expects locals: recommended_way (ServiceV3 or ServiceAreaV3 instance)
  # Renders the scannable high-level "Summary" version of "Forma Recomendada".
  rw_title   = recommended_way ? recommended_way.recommended_way_title.to_s.strip : ''
  rw_note    = recommended_way ? recommended_way.recommended_way_note.to_s.strip  : ''
  rw_summary = recommended_way ? recommended_way.recommended_way_summary.to_s     : ''
%>

<% unless rw_summary.strip.empty? && rw_title.empty? %>
<section class="recommended-way recommended-way-summary mt-4 mb-4"
         style="border: 3px solid <%= @primary_color || '#68CEF2' %>; border-radius: 12px; overflow: hidden;">
  <div class="recommended-way-header px-4 py-3" style="background: <%= @primary_color || '#68CEF2' %>; color: <%= @primary_font_color || '#000' %>;">
    <div class="d-flex align-items-center gap-2">
      <h3 class="mb-0" style="font-weight: 700;">
        <%= rw_title.empty? ? "Forma recomendada" : rw_title %>
      </h3>
    </div>
    <% unless rw_note.empty? %>
      <p class="mt-2 mb-0 small" style="opacity: 0.95;">
        <strong><%= rw_note %></strong>
      </p>
    <% else %>
      <p class="mt-2 mb-0 small" style="opacity: 0.9;">
        El camino que funciona para la mayoría de las empresas.
      </p>
    <% end %>
  </div>

  <div class="recommended-way-body p-4" style="background: white;">
    <% unless rw_summary.strip.empty? %>
      <div class="recommended-way-steps-content">
        <%= rw_summary %>
      </div>
    <% end %>

    <div class="mt-3">
      <a href="#forma-recomendada" class="btn btn-sm" style="border: 2px solid <%= @primary_color || '#68CEF2' %>; color: <%= @primary_color || '#68CEF2' %>; border-radius: 50px; padding: 6px 18px; font-weight: 600;">
        Ver el enfoque completo →
      </a>
    </div>
  </div>
</section>
<% end %>
