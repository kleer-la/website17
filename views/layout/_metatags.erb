<%= @meta_tags.display site: 'Kleer', base_url: 'https://www.kleer.la', current_lang: session[:locale] %>
<meta name="author" content="Kleer - https://www.kleer.la">
<meta property="og:type" content="website" />
<meta property="og:site_name" content="Kleer" />
<meta property="og:locale" content="<%= session[:locale] == 'en' ? 'en_US' : 'es_ES' %>" />
<meta property="og:locale:alternate" content="<%= session[:locale] == 'en' ? 'es_ES' : 'en_US' %>" />
<meta property="fb:app_id" content="116606177078" />
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:site" content="@klaborativa">
<meta http-equiv="Cache-control" content="public">
<link rel="shortcut icon" href="/favicon.ico">
<%= json_ld_tag(organization_json_ld) %>
<%= json_ld_tag(website_json_ld) %>
<% if @json_ld.is_a?(Array) %>
<%= @json_ld.map { |ld| json_ld_tag(ld) }.join("\n") %>
<% elsif @json_ld %>
<%= json_ld_tag(@json_ld) %>
<% end %>
