<section class="area-hero-full position-relative d-flex align-items-center justify-content-center overflow-hidden"
  style="min-height: 100vh; margin-top: 0;">
  <!-- Background with overlay -->
  <div class="position-absolute top-0 start-0 w-100 h-100" style="z-index: 0;">
    <img src="https://kleer-images.s3.sa-east-1.amazonaws.com/dol+grupo+personas+interactiando+" alt="<%= service_area.name %>"
      class="w-100 h-100" style="object-fit: cover;" loading="eager"/>
    <div class="position-absolute top-0 start-0 w-100 h-100"
      style="background-color: <%= @primary_color %>; opacity: 0.7; mix-blend-mode: multiply;"></div>
    <div class="position-absolute top-0 start-0 w-100 h-100"
      style="background: linear-gradient(to bottom, rgba(0,0,0,0.6), rgba(0,0,0,0.3) 50%, rgba(0,0,0,0.05));"></div>
  </div>

  <!-- Content -->
  <div class="position-relative text-center text-white px-3" style="z-index: 2; max-width: 1100px; width: 100%;">
    <!-- Title -->
    <h1 class="text-uppercase mb-3"
      style="font-family: 'Raleway', sans-serif; font-weight: 700; font-size: clamp(1.25rem, 2.5vw, 1.75rem); line-height: 1.3; letter-spacing: 0.15em; opacity: 0.9;">
      <%= service_area.name %>
    </h1>

    <!-- Slogan -->
    <% if service_area.slogan && service_area.slogan != '' %>
      <h2 class="mb-4"
        style="font-family: 'Raleway', sans-serif; font-weight: 800; font-size: clamp(2.5rem, 6vw, 4.5rem); line-height: 1.1; letter-spacing: -0.02em;">
        <%= service_area.slogan %>
      </h2>
    <% end %>

    <!-- Description -->
    <% if service_area.description && service_area.description != '' %>
      <div class="mx-auto mb-5" style="max-width: 900px;">
        <p style="font-family: 'Raleway', sans-serif; font-size: 1.15rem; line-height: 1.7; opacity: 0.9;">
          <%= service_area.description %>
        </p>
      </div>
    <% end %>

    <!-- Service links -->
    <% if service_area.services.any? %>
      <div class="d-flex flex-column flex-sm-row justify-content-center align-items-center gap-4 mb-5">
        <% service_area.services.each do |service| %>
          <a href="/es/<%= @path %>/<%= service_area.slug %>/<%= service.slug %>"
            class="area-hero-service-link d-flex align-items-center gap-2 text-white text-decoration-none"
            style="font-family: 'Raleway', sans-serif; font-weight: 700; font-size: 1.4rem; transition: opacity 0.2s;">
            <%= service.name %>
            <i class="fas fa-arrow-right" style="color: <%= @secondary_color %>; transition: transform 0.2s;"></i>
          </a>
        <% end %>
      </div>
    <% end %>

    <!-- CTA Button -->
    <%= erb :'component/_contact_banner_button',
            locals: {
              style: "background-color: #{@secondary_color}; color: #{@secondary_font_color}; font-family: 'Raleway', sans-serif; font-weight: 800; font-size: 1.1rem; padding: 16px 48px; border-radius: 50px; border: none; box-shadow: 0 8px 32px rgba(0,0,0,0.3); transition: transform 0.2s;",
              text_button: hero_cta,
              style_class: 'btn area-hero-cta-btn',
              specific_id: "area-hero-cta"
            } %>
  </div>
</section>

<style>
  .area-hero-full {
    margin-top: 0 !important;
  }
  .area-hero-service-link:hover {
    opacity: 0.8;
  }
  .area-hero-service-link:hover .fas {
    transform: translateX(4px);
  }
  .area-hero-cta-btn:hover {
    transform: scale(1.05);
  }
  .area-hero-cta-btn:active {
    transform: scale(0.95);
  }
</style>
