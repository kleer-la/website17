<div class="program">
  <h4>
    <%= t("services.program.#{@is_training_program==true}", name: name) %>
  </h4>
  <div class="row mt-5 w-100">
    <% program.each.with_index do |item, index| %>
     <div class="col-12 col-lg-6">
       <div class="program-item row">
         <div class="col-12">
           <h5><%= item[0] %></h5>
           <p class="detail"><%= item[1] %></p>
         </div>
       </div>
     </div>
    <% end %>
  </div>
</div>
