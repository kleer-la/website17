<h2 class="mb-2" style="font-size: 1.1rem;"><%= t('booking.select_time') %></h2>

<div id="consultants-list" class="row g-2">
  <div class="col-12 mb-1">
    <small class="text-muted" id="booking-timezone-label"></small>
    <input type="hidden" id="booking-timezone">
  </div>
  <% consultants.each do |consultant| %>
    <div class="col-md-6">
      <div class="card consultant-card" data-consultant-id="<%= consultant['id'] %>">
        <div class="card-body py-2 px-3">
          <div class="d-flex align-items-center mb-2">
            <img src="https://www.gravatar.com/avatar/<%= Digest::MD5.hexdigest(consultant['gravatar_email'].to_s.downcase.strip) %>?s=36&d=mp"
                 class="rounded-circle me-2" width="36" height="36" alt="<%= consultant['name'] %>">
            <div>
              <h5 class="card-title mb-0" style="font-size: 0.95rem;"><%= consultant['name'] %></h5>
              <% if consultant['bio'] %>
                <details><summary class="text-muted" style="font-size: 0.8rem; cursor: pointer;">bio</summary><small class="text-muted"><%= consultant['bio'] %></small></details>
              <% end %>
            </div>
          </div>
          <div class="availability-slots">
            <div class="text-center py-2">
              <div class="spinner-border spinner-border-sm" role="status">
                <span class="visually-hidden">Loading...</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>

<div class="text-center mt-3">
  <form action="/<%= session[:locale] || 'es' %>/send-booking-inquiry" method="post" class="d-inline">
    <input type="hidden" name="booking_token" value="<%= booking_token %>">
    <input type="hidden" name="area_slug" value="<%= slug %>">
    <button type="submit" class="btn my-secondary-button">
      <%= t('booking.send_option') %>
    </button>
  </form>
</div>

<script>
  var BOOKING_CONFIG = {
    token: '<%= booking_token %>',
    areaSlug: '<%= slug %>',
    serviceAreaId: '<%= service_area.id %>',
    visitorName: <%= visitor_name.to_json %>,
    visitorEmail: <%= visitor_email.to_json %>,
    visitorCompany: <%= visitor_company.to_json %>,
    visitorMessage: <%= visitor_message.to_json %>,
    locale: '<%= session[:locale] || "es" %>',
    consultantIds: <%= consultants.map { |c| c['id'] }.to_json %>,
    confirmText: '<%= t("booking.confirm_booking") %>',
    confirmedText: '<%= t("booking.meeting_confirmed") %>',
    noSlotsText: '<%= t("booking.no_availability") %>',
    loadErrorText: '<%= t("booking.load_error") %>'
  };
</script>
