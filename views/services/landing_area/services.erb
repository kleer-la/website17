<div class="services-section">
  <div class="introduce">
    <img src="/app/img/icons/Glasses.svg" loading="lazy"/>
    <h2>
      <%= area.cta_message ? area.cta_message.gsub(/<[^>]*>/, '').strip : '' %>
    </h2>
  </div>

  <div class="container">
    <div class="row justify-content-center" style="gap: 2rem 0;">
      <% services.each do |service| %>
        <% card_html = service.card_description.to_s.strip %>
        <% if card_html.empty? %>
          <div class="col-md-4 mb-4">
            <%= erb :'services/components/_service_preview_card',
                    locals: {
                      service: service,
                      area_slug: area.slug,
                      primary_color: area.primary_color
                    } %>
          </div>
        <% else %>
          <div class="col-12 mb-4">
            <%= erb :'services/components/_service_details_card',
                    locals: {
                      card_html: card_html,
                      primary_color: area.primary_color
                    } %>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
